<%- include('partials/header', { pageTitle: subscription.name + ' — Usage' }) %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <a href="/subscriptions" class="text-xs text-brand-600 hover:underline flex items-center gap-1 mb-2 font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back
    </a>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-bold text-slate-900 tracking-tight"><%= subscription.name %></h1>
        <div class="flex items-center gap-2 mt-1">
          <span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded text-xs font-medium"><%= subscription.category %></span>
          <span class="text-sm text-slate-500">$<%= subscription.cost.toFixed(2) %> / <%= subscription.billingCycle %></span>
        </div>
      </div>
      <button onclick="logUsage('<%= subscription._id %>')"
        class="mt-3 sm:mt-0 px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-md hover:bg-emerald-500 transition">
        Log Usage
      </button>
    </div>
  </div>

  <div class="bg-white rounded-lg border border-slate-200">
    <div class="px-5 py-4 border-b border-slate-100">
      <h2 class="text-sm font-semibold text-slate-900">Usage History</h2>
      <p class="text-xs text-slate-400 mt-0.5"><%= logs.length %> entries</p>
    </div>

    <% if (logs.length > 0) { %>
      <div class="divide-y divide-slate-50">
        <% logs.forEach(function(log) { %>
          <div class="flex items-center justify-between px-5 py-3 hover:bg-slate-50 transition">
            <div class="flex items-center gap-2.5">
              <div class="w-2 h-2 rounded-full <%= log.action === 'used' ? 'bg-emerald-500' : 'bg-slate-300' %>"></div>
              <span class="text-sm font-medium text-slate-700 capitalize"><%= log.action.replace('_', ' ') %></span>
              <% if (log.notes) { %>
                <span class="text-xs text-slate-400">— <%= log.notes %></span>
              <% } %>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs text-slate-400"><%= new Date(log.date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %></span>
              <button onclick="deleteUsageLog('<%= log._id %>')" class="text-slate-300 hover:text-rose-500 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="p-10 text-center text-slate-400 text-sm">
        No usage recorded yet.
        <button onclick="logUsage('<%= subscription._id %>')" class="text-brand-600 hover:underline font-medium ml-1">Log first use</button>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
