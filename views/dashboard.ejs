<%- include('partials/header', { pageTitle: 'Dashboard' }) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <h1 class="text-xl font-bold text-slate-900 tracking-tight">Dashboard</h1>
    <p class="text-slate-500 text-sm">Monthly subscription overview</p>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg border border-slate-200 p-4 stat-card stat-card-indigo">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Subscriptions</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
      </div>
      <div class="text-2xl font-bold text-slate-900"><%= totalSubs %></div>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4 stat-card stat-card-emerald">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Monthly Spend</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" /></svg>
      </div>
      <div class="text-2xl font-bold text-slate-900">$<%= totalMonthlySpend %></div>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4 stat-card stat-card-amber">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Uses</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
      </div>
      <div class="text-2xl font-bold text-slate-900"><%= usesThisMonth %></div>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4 stat-card stat-card-rose">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Avg Cost/Use</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
      </div>
      <div class="text-2xl font-bold text-slate-900"><%= avgCostPerUse === 'N/A' ? '—' : '$' + avgCostPerUse %></div>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <div class="bg-white rounded-lg border border-slate-200 p-5">
      <h2 class="text-sm font-semibold text-slate-900 mb-3">Spending by Category</h2>
      <% if (Object.keys(categorySpend).length > 0) { %>
        <div class="relative h-56">
          <canvas id="categoryChart"></canvas>
        </div>
      <% } else { %>
        <div class="flex items-center justify-center h-56 text-slate-400 text-sm">
          No data yet
        </div>
      <% } %>
    </div>

    <div class="lg:col-span-2 bg-white rounded-lg border border-slate-200 p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-slate-900">Recent Activity</h2>
        <a href="/subscriptions" class="text-xs text-brand-600 hover:underline font-medium">View all</a>
      </div>
      <% if (recentLogs.length > 0) { %>
        <div class="space-y-2">
          <% recentLogs.forEach(function(log) { %>
            <div class="flex items-center justify-between py-2 px-3 rounded-md bg-slate-50">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full <%= log.action === 'used' ? 'bg-emerald-500' : 'bg-slate-300' %>"></div>
                <span class="text-sm font-medium text-slate-700"><%= log.subscription ? log.subscription.name : 'Unknown' %></span>
                <span class="text-xs text-slate-400"><%= log.action %></span>
              </div>
              <span class="text-xs text-slate-400"><%= new Date(log.date).toLocaleDateString() %></span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-8 text-slate-400 text-sm">No usage logged yet.</div>
      <% } %>
    </div>
  </div>

  <div class="mt-6 bg-white rounded-lg border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-slate-900">Subscriptions</h2>
      <a href="/subscriptions" class="text-xs text-brand-600 hover:underline font-medium">Manage</a>
    </div>
    <% if (subscriptions.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs text-slate-500 uppercase tracking-wide border-b border-slate-100">
              <th class="pb-2 font-medium">Name</th>
              <th class="pb-2 font-medium">Category</th>
              <th class="pb-2 font-medium">Cost</th>
              <th class="pb-2 font-medium">Cycle</th>
              <th class="pb-2 font-medium text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% subscriptions.forEach(function(sub) { %>
              <tr class="border-b border-slate-50 table-row-alt">
                <td class="py-2.5 font-medium text-slate-800"><%= sub.name %></td>
                <td class="py-2.5 text-slate-500"><%= sub.category %></td>
                <td class="py-2.5 text-slate-800">$<%= sub.cost.toFixed(2) %></td>
                <td class="py-2.5"><span class="px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600"><%= sub.billingCycle %></span></td>
                <td class="py-2.5 text-right">
                  <button onclick="logUsage('<%= sub._id %>')" class="px-2.5 py-1 text-xs font-medium bg-emerald-50 text-emerald-700 rounded hover:bg-emerald-100 transition">Log Use</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-6 text-slate-400 text-sm">
        <a href="/subscriptions" class="text-brand-600 hover:underline">Add your first subscription</a>
      </div>
    <% } %>
  </div>
</div>

<% if (Object.keys(categorySpend).length > 0) { %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    initCategoryChart(<%- JSON.stringify(categorySpend) %>);
  });
</script>
<% } %>

<%- include('partials/footer') %>
