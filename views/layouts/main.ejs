<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="SubGenie — AI-powered subscription management. Track usage, analyze costs, and stop overspending." />
  <meta name="theme-color" content="#6366f1" />
  <title>SubGenie — <%= typeof pageTitle !== 'undefined' ? pageTitle : 'Subscription Intelligence' %></title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Tailwind (CDN) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
          colors: {
            brand: {
              50:  '#eef2ff', 100: '#e0e7ff', 200: '#c7d2fe',
              300: '#a5b4fc', 400: '#818cf8', 500: '#6366f1',
              600: '#4f46e5', 700: '#4338ca', 800: '#3730a3', 900: '#312e81',
            },
          },
        },
      },
    };
  </script>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>

  <!-- Custom styles -->
  <link rel="stylesheet" href="/css/custom.css?v=3" />

  <!-- Auth token for API calls (injected server-side, only on app pages) -->
  <% if (typeof authToken !== 'undefined' && authToken) { %>
  <script>window._authToken = '<%= authToken %>';</script>
  <% } else { %>
  <script>window._authToken = '';</script>
  <% } %>
</head>

<% if (typeof isAppPage !== 'undefined' && isAppPage) { %>
<!-- ═══════════════════════════════════════════════════════════════════════════
     APP LAYOUT  — sidebar + main content
     ═══════════════════════════════════════════════════════════════════════════ -->
<body class="font-sans antialiased" style="margin:0; padding:0;">
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="main-content" id="mainContent">
      <!-- App topbar (mobile hamburger + page title) -->
      <div class="app-topbar">
        <div class="flex items-center gap-3">
          <!-- Mobile hamburger -->
          <button onclick="openSidebar()" class="md:hidden p-1.5 rounded-lg hover:bg-slate-200/60 transition text-slate-600" aria-label="Open menu">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <div>
            <h1 class="text-[15px] font-semibold text-slate-800 leading-tight"><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></h1>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <!-- Quick add button -->
          <% if (typeof pageTitle !== 'undefined' && (pageTitle === 'Dashboard' || pageTitle === 'Subscriptions')) { %>
          <button onclick="openAddModal()" class="btn-primary px-3 py-1.5 text-white text-xs font-semibold rounded-lg flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add
          </button>
          <% } %>
          <!-- User avatar (mobile) -->
          <% if (typeof user !== 'undefined' && user) { %>
          <a href="/profile" class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-xs font-bold text-white shadow-md">
            <%= user.name.charAt(0).toUpperCase() %>
          </a>
          <% } %>
        </div>
      </div>

      <!-- Page content -->
      <div class="px-4 sm:px-6 lg:px-8 py-6 max-w-7xl mx-auto">
        <%- body %>
      </div>
    </div>
  </div>

  <!-- Toast container -->
  <div id="toast-container"></div>

  <!-- ─── AI Chat Widget ───────────────────────────────────────────────────── -->
  <div id="chat-widget">
    <button id="chat-toggle" onclick="toggleChat()" aria-label="Open AI assistant">
      <svg id="chat-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
      <svg id="chat-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <div id="chat-panel" class="chat-panel-hidden">
      <div class="chat-header">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-xl bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold text-white leading-tight">SubGenie AI</div>
            <div class="text-xs text-white/60 leading-tight">Always here to help</div>
          </div>
        </div>
        <button onclick="clearChat()" title="Clear chat" class="text-white/50 hover:text-white transition text-xs font-medium">Clear</button>
      </div>
      <div id="chat-messages" class="chat-messages">
        <div class="chat-bubble bot">
          Hey! I'm your SubGenie assistant 👋<br>Talk to me naturally — log usage, add subscriptions, check your spending, anything!
        </div>
      </div>
      <div class="chat-input-area">
        <input id="chat-input" type="text" placeholder="Message SubGenie AI…" autocomplete="off"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendChatMessage();}" maxlength="300"/>
        <button onclick="sendChatMessage()" id="chat-send-btn" aria-label="Send">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <script src="/js/main.js?v=3"></script>
  <script>
    function openSidebar() {
      document.getElementById('sidebar').classList.add('open');
      document.getElementById('sidebarOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('open');
      document.getElementById('sidebarOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }
  </script>
</body>

<% } else { %>
<!-- ═══════════════════════════════════════════════════════════════════════════
     PUBLIC LAYOUT  — top nav + footer
     ═══════════════════════════════════════════════════════════════════════════ -->
<body class="bg-[#f8f9fb] text-slate-800 min-h-screen flex flex-col font-sans antialiased">
  <%- include('../partials/header') %>
  <main class="flex-1">
    <%- body %>
  </main>
  <%- include('../partials/footer') %>
  <!-- Toast container -->
  <div id="toast-container"></div>
  <script src="/js/main.js"></script>
</body>
<% } %>
</html>
