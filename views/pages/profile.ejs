<div class="max-w-2xl">
  <!-- ─── Profile Card ───────────────────────────────────────────────────── -->
  <div class="card p-6 mb-5 animate-fade-in-up">
    <div class="flex items-center gap-5">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-500 to-violet-600 flex items-center justify-center text-2xl font-bold text-white shadow-lg shadow-brand-500/25">
        <%= user.name.charAt(0).toUpperCase() %>
      </div>
      <div>
        <h2 class="text-xl font-bold text-slate-900"><%= user.name %></h2>
        <p class="text-sm text-slate-500"><%= user.email %></p>
        <div class="flex items-center gap-2 mt-1.5">
          <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold
            <%= user.role === 'admin' ? 'bg-amber-100 text-amber-800 border border-amber-200' : 'bg-slate-100 text-slate-600 border border-slate-200' %>">
            <% if (user.role === 'admin') { %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <% } %>
            <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
          </span>
          <span class="text-xs text-slate-400">
            Member since <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── Alert messages ─────────────────────────────────────────────────── -->
  <% if (success) { %>
    <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm rounded-xl mb-4 animate-fade-in-up">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <%= success %>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="flex items-center gap-3 p-4 bg-rose-50 border border-rose-200 text-rose-800 text-sm rounded-xl mb-4 animate-fade-in-up">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-rose-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.072 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
      <%= error %>
    </div>
  <% } %>

  <!-- ─── Edit Form ───────────────────────────────────────────────────────── -->
  <div class="card p-6 animate-fade-in-up stagger-1">
    <h3 class="text-sm font-bold text-slate-900 mb-5 pb-3 border-b border-slate-100">Edit Profile</h3>
    <form id="profileForm" action="/profile" method="POST" novalidate class="space-y-4">
      <div>
        <label class="form-label">Full Name</label>
        <input type="text" name="name" id="profileName" value="<%= user.name %>" class="form-input" placeholder="Your name" />
        <p id="errProfileName" class="text-xs text-rose-600 mt-1 hidden"></p>
      </div>
      <div>
        <label class="form-label">Email Address</label>
        <input type="email" name="email" id="profileEmail" value="<%= user.email %>" class="form-input" placeholder="you@example.com" />
        <p id="errProfileEmail" class="text-xs text-rose-600 mt-1 hidden"></p>
      </div>

      <div class="pt-2 border-t border-slate-100">
        <p class="text-xs text-slate-500 mb-3 font-medium">Change Password (leave blank to keep current)</p>
        <div class="space-y-3">
          <div>
            <label class="form-label">New Password</label>
            <input type="password" name="password" id="profilePassword" class="form-input" placeholder="Min. 6 characters" />
            <p id="errProfilePassword" class="text-xs text-rose-600 mt-1 hidden"></p>
            <div id="strengthBar" class="hidden mt-2">
              <div class="w-full bg-slate-200 rounded-full h-1.5">
                <div id="strengthFill" class="h-1.5 rounded-full transition-all" style="width: 0%"></div>
              </div>
              <p id="strengthLabel" class="text-xs mt-1 text-slate-400"></p>
            </div>
          </div>
          <div>
            <label class="form-label">Confirm New Password</label>
            <input type="password" name="confirmPassword" id="profileConfirmPassword" class="form-input" placeholder="Repeat password" />
            <p id="errProfileConfirm" class="text-xs text-rose-600 mt-1 hidden"></p>
          </div>
        </div>
      </div>

      <button type="submit" class="btn-primary px-6 py-2.5 text-white text-sm font-bold rounded-xl">
        Save Changes
      </button>
    </form>
  </div>

  <!-- ─── Danger Zone ────────────────────────────────────────────────────── -->
  <div class="card p-5 mt-4 border-rose-200 animate-fade-in-up stagger-2">
    <h3 class="text-sm font-bold text-rose-700 mb-3">Sign Out</h3>
    <p class="text-xs text-slate-500 mb-3">End your current session across all devices.</p>
    <a href="/logout" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-rose-600 bg-rose-50 border border-rose-200 rounded-xl hover:bg-rose-100 transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
      Sign Out
    </a>
  </div>
</div>

<script>
(function() {
  const pw   = document.getElementById('profilePassword');
  const bar  = document.getElementById('strengthBar');
  const fill = document.getElementById('strengthFill');
  const lbl  = document.getElementById('strengthLabel');

  pw.addEventListener('input', function() {
    if (!pw.value) { bar.classList.add('hidden'); return; }
    bar.classList.remove('hidden');
    let score = 0;
    if (pw.value.length >= 8) score++;
    if (/[A-Z]/.test(pw.value)) score++;
    if (/[0-9]/.test(pw.value)) score++;
    if (/[^A-Za-z0-9]/.test(pw.value)) score++;
    const lvls = [
      { w:'25%',c:'bg-rose-500',t:'Weak' },
      { w:'50%',c:'bg-amber-500',t:'Fair' },
      { w:'75%',c:'bg-yellow-500',t:'Good' },
      { w:'100%',c:'bg-emerald-500',t:'Strong' },
    ];
    const l = lvls[Math.max(0, score-1)] || lvls[0];
    fill.style.width = l.w;
    fill.className = 'h-1.5 rounded-full transition-all ' + l.c;
    lbl.textContent = l.t;
  });

  document.getElementById('profileForm').addEventListener('submit', function(e) {
    let ok = true;
    ['errProfileName','errProfileEmail','errProfilePassword','errProfileConfirm'].forEach(id => {
      document.getElementById(id).classList.add('hidden');
    });
    const name    = document.getElementById('profileName').value.trim();
    const email   = document.getElementById('profileEmail').value.trim();
    const pass    = document.getElementById('profilePassword').value;
    const confirm = document.getElementById('profileConfirmPassword').value;
    if (!name)  { show('errProfileName', 'Name is required'); ok = false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { show('errProfileEmail', 'Enter a valid email'); ok = false; }
    if (pass && pass.length < 6) { show('errProfilePassword', 'Minimum 6 characters'); ok = false; }
    if (pass && pass !== confirm) { show('errProfileConfirm', 'Passwords do not match'); ok = false; }
    if (!ok) e.preventDefault();
  });

  function show(id, msg) {
    const el = document.getElementById(id);
    el.textContent = msg;
    el.classList.remove('hidden');
  }
})();
</script>
