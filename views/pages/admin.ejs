<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="flex items-center gap-3 mb-6">
    <div>
      <h1 class="text-xl font-bold text-slate-900 tracking-tight">Admin Panel</h1>
      <p class="text-slate-500 text-sm">Manage users and roles</p>
    </div>
    <span class="px-2 py-0.5 bg-amber-100 text-amber-800 text-xs font-medium rounded">Restricted</span>
  </div>

  <% if (success) { %>
    <div class="mb-4 p-3 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-md"><%= success %></div>
  <% } %>

  <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50 border-b border-slate-200">
            <th class="px-5 py-3 font-medium">User</th>
            <th class="px-5 py-3 font-medium">Email</th>
            <th class="px-5 py-3 font-medium text-center">Subscriptions</th>
            <th class="px-5 py-3 font-medium text-center">Role</th>
            <th class="px-5 py-3 font-medium text-right">Change Role</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u) { %>
            <tr class="border-b border-slate-50 table-row-alt hover:bg-slate-50 transition">
              <td class="px-5 py-3">
                <div class="flex items-center gap-2.5">
                  <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center text-xs font-bold text-white uppercase"><%= u.name.charAt(0) %></div>
                  <div>
                    <span class="font-medium text-slate-800"><%= u.name %></span>
                    <% if (u._id.toString() === user._id.toString()) { %>
                      <span class="text-xs text-slate-400 ml-1">(you)</span>
                    <% } %>
                  </div>
                </div>
              </td>
              <td class="px-5 py-3 text-slate-500"><%= u.email %></td>
              <td class="px-5 py-3 text-center text-slate-700"><%= u.subCount %></td>
              <td class="px-5 py-3 text-center">
                <span class="px-2 py-0.5 rounded text-xs font-medium <%= u.role === 'admin' ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-600' %>"><%= u.role %></span>
              </td>
              <td class="px-5 py-3 text-right">
                <% if (u._id.toString() === user._id.toString()) { %>
                  <span class="text-xs text-slate-400">&mdash;</span>
                <% } else { %>
                  <form action="/admin/role/<%= u._id %>" method="POST" class="flex items-center justify-end gap-2">
                    <select name="role" class="px-2 py-1 text-xs border border-slate-300 rounded-md bg-white">
                      <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
                      <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
                    </select>
                    <button type="submit" class="px-2.5 py-1 text-xs font-medium bg-brand-600 text-white rounded-md hover:bg-brand-500 transition">Update</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
