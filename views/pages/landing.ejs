              <!-- Bot message -->
              <div class="self-start max-w-[85%] animate-fade-in-up stagger-1">
                <div class="bg-white text-slate-700 px-4 py-3 rounded-2xl rounded-tl-sm text-[13px] font-medium shadow-sm border border-slate-100/50">
                  Welcome to SubGenie! 🧞‍♂️<br><br>Your account is linked. To log a usage, just type <b>/used [service]</b>.
                  <div class="text-[9px] text-slate-400 text-right mt-1.5 font-semibold">10:41 AM</div>
                </div>
              </div>
              
              <!-- User message -->
              <div class="self-end max-w-[85%] animate-fade-in-up stagger-2">
                <div class="bg-blue-500 text-white px-4 py-3 rounded-2xl rounded-tr-sm text-[13px] font-medium shadow-sm shadow-blue-500/10">
                  /used Netflix
                  <div class="text-[9px] text-blue-200 text-right mt-1.5 font-semibold">10:45 AM ✓</div>
                </div>
              </div>
              
              <!-- Bot message -->
              <div class="self-start max-w-[85%] animate-fade-in-up stagger-3">
                <div class="bg-white text-slate-700 px-4 py-3 rounded-2xl rounded-tl-sm text-[13px] font-medium shadow-sm border border-slate-100/50 relative overflow-hidden">
                  <div class="absolute top-0 left-0 w-1 h-full bg-emerald-400"></div>
                  <div class="flex gap-2">
                    <span class="text-base leading-none">✅</span>
                    <div>
                      Logged 1 use for <span class="font-bold text-slate-900">Netflix</span>.<br>
                      <span class="text-slate-500 text-xs mt-1.5 block leading-relaxed">You've used Netflix 12 times this month. Your cost per use is now <span class="font-bold text-emerald-600">$1.29</span>.</span>
                    </div>
                  </div>
                  <div class="text-[9px] text-slate-400 text-right mt-1.5 font-semibold">10:45 AM</div>
                </div>
              </div>
            </div>
            
            <!-- Message Input Area -->
            <div class="bg-white p-3 border-t border-slate-100">
              <div class="bg-slate-50 rounded-full px-4 py-2.5 flex items-center gap-3 border border-slate-200/60">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" /></svg>
                <div class="text-slate-400 text-sm font-medium flex-1">Message...</div>
                <div class="w-7 h-7 bg-blue-500 rounded-full flex items-center justify-center shadow-sm text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 0l-3 3a1 1 0 001.414 1.414L9 9.414V13a1 1 0 102 0V9.414l1.293 1.293a1 1 0 001.414-1.414z" clip-rule="evenodd" /></svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

