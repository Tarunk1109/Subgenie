      <p class="text-slate-500 text-base mt-4 max-w-lg mx-auto font-medium">No credit card required. Start tracking in under a minute.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="group card p-8 animate-fade-in-up stagger-1 relative bg-[#fafafa] border border-slate-200 hover:border-slate-300 transition-colors shadow-none hover:shadow-sm rounded-2xl">
