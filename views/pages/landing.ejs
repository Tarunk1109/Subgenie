
<section class="hero-mesh relative overflow-hidden -mt-px">
  <div class="hero-grid absolute inset-0"></div>
  <div class="absolute top-20 left-1/4 w-72 h-72 bg-brand-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 right-1/4 w-96 h-96 bg-violet-500/8 rounded-full blur-3xl"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-brand-300 text-xs font-medium mb-8 animate-fade-in-up backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        AI-Powered Subscription Intelligence
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.1] animate-fade-in-up stagger-1">
        Know exactly what your<br/>
        subscriptions <span class="gradient-text">really cost</span>
      </h1>

      <p class="mt-6 text-base sm:text-lg text-slate-400 max-w-xl mx-auto leading-relaxed animate-fade-in-up stagger-2">
        Track usage, analyze cost-per-use, and get AI recommendations to stop overspending on subscriptions you barely use.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center animate-fade-in-up stagger-3">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="btn-primary px-7 py-3 text-white font-semibold rounded-xl text-sm">
            Go to Dashboard
          </a>
        <% } else { %>
          <a href="/register" class="btn-primary px-7 py-3 text-white font-semibold rounded-xl text-sm">
            Get Started Free
          </a>
          <a href="/login" class="px-7 py-3 bg-white/5 text-slate-300 font-semibold rounded-xl border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all text-sm backdrop-blur-sm">
            Sign In
          </a>
        <% } %>
      </div>

      <!-- Mini dashboard preview -->
      <div class="mt-16 animate-fade-in-up stagger-4">
        <div class="max-w-2xl mx-auto bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 p-6 shadow-2xl shadow-black/20">
          <div class="grid grid-cols-3 gap-4 mb-4">
            <div class="bg-white/5 rounded-xl p-3 border border-white/5">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider mb-1">Monthly</div>
              <div class="text-xl font-bold text-white">$127</div>
            </div>
            <div class="bg-white/5 rounded-xl p-3 border border-white/5">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider mb-1">Active</div>
              <div class="text-xl font-bold text-white">8</div>
            </div>
            <div class="bg-white/5 rounded-xl p-3 border border-white/5">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider mb-1">Savings</div>
              <div class="text-xl font-bold text-emerald-400">$43</div>
            </div>
          </div>
          <div class="space-y-2">
            <div class="flex items-center justify-between bg-white/5 rounded-lg px-3 py-2">
              <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-rose-400"></div><span class="text-xs text-slate-300">Adobe CC</span></div>
              <span class="text-xs text-rose-400">Unused</span>
            </div>
            <div class="flex items-center justify-between bg-white/5 rounded-lg px-3 py-2">
              <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-emerald-400"></div><span class="text-xs text-slate-300">Netflix</span></div>
              <span class="text-xs text-emerald-400">12 uses</span>
            </div>
            <div class="flex items-center justify-between bg-white/5 rounded-lg px-3 py-2">
              <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-amber-400"></div><span class="text-xs text-slate-300">Spotify</span></div>
              <span class="text-xs text-amber-400">3 uses</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-20 relative">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-xs font-semibold text-brand-500 uppercase tracking-widest mb-2">How it works</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">Three steps to financial clarity</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card-solid p-6 animate-fade-in-up stagger-1">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-brand-600 flex items-center justify-center text-white text-sm font-bold mb-4 shadow-lg shadow-brand-500/20">1</div>
        <h3 class="text-sm font-bold text-slate-900 mb-2">Add Subscriptions</h3>
        <p class="text-sm text-slate-500 leading-relaxed">Track Netflix, Spotify, gym, SaaS tools -- anything with a recurring cost. Web or Telegram.</p>
      </div>
      <div class="card-solid p-6 animate-fade-in-up stagger-2">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center text-white text-sm font-bold mb-4 shadow-lg shadow-emerald-500/20">2</div>
        <h3 class="text-sm font-bold text-slate-900 mb-2">Log Usage</h3>
        <p class="text-sm text-slate-500 leading-relaxed">One click to record when you use a service. Build a real usage history over time.</p>
      </div>
      <div class="card-solid p-6 animate-fade-in-up stagger-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500 to-violet-600 flex items-center justify-center text-white text-sm font-bold mb-4 shadow-lg shadow-violet-500/20">3</div>
        <h3 class="text-sm font-bold text-slate-900 mb-2">Get AI Insights</h3>
        <p class="text-sm text-slate-500 leading-relaxed">GPT analyzes your data: cost-per-use, cheaper alternatives, and exactly what to cancel.</p>
      </div>
    </div>
  </div>
</section>

<section class="py-20 bg-slate-900 relative overflow-hidden">
  <div class="absolute inset-0 hero-grid opacity-50"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500/5 rounded-full blur-3xl"></div>
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-xs font-semibold text-brand-400 uppercase tracking-widest mb-2">Capabilities</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">Everything you need to declutter</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white/5 backdrop-blur-sm p-5 rounded-xl border border-white/10 hover:border-brand-500/30 transition-all group">
        <div class="w-9 h-9 rounded-lg bg-brand-500/15 text-brand-400 flex items-center justify-center mb-3 group-hover:bg-brand-500/25 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Cost Tracking</h3>
        <p class="text-xs text-slate-400 leading-relaxed">Monthly spend breakdown with category charts.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm p-5 rounded-xl border border-white/10 hover:border-emerald-500/30 transition-all group">
        <div class="w-9 h-9 rounded-lg bg-emerald-500/15 text-emerald-400 flex items-center justify-center mb-3 group-hover:bg-emerald-500/25 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Usage Analytics</h3>
        <p class="text-xs text-slate-400 leading-relaxed">Track exactly how often you use each service.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm p-5 rounded-xl border border-white/10 hover:border-violet-500/30 transition-all group">
        <div class="w-9 h-9 rounded-lg bg-violet-500/15 text-violet-400 flex items-center justify-center mb-3 group-hover:bg-violet-500/25 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">AI Advisor</h3>
        <p class="text-xs text-slate-400 leading-relaxed">GPT-powered savings and alternative suggestions.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm p-5 rounded-xl border border-white/10 hover:border-sky-500/30 transition-all group">
        <div class="w-9 h-9 rounded-lg bg-sky-500/15 text-sky-400 flex items-center justify-center mb-3 group-hover:bg-sky-500/25 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
        </div>
        <h3 class="text-sm font-semibold text-white mb-1">Telegram Bot</h3>
        <p class="text-xs text-slate-400 leading-relaxed">Full control from your chat with daily reminders.</p>
      </div>
    </div>
  </div>
</section>
