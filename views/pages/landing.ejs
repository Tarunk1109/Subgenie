<!-- ─── Hero ───────────────────────────────────────────────────────────────── -->
<section class="hero-mesh relative overflow-hidden -mt-px">
  <div class="hero-grid absolute inset-0"></div>
  <!-- Floating orbs -->
  <div class="absolute top-16 left-1/4 w-80 h-80 bg-brand-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-8 right-1/5 w-96 h-96 bg-violet-500/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
    <div class="text-center">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-brand-300 text-xs font-medium mb-10 animate-fade-in-up backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
        </span>
        AI-Powered Subscription Intelligence
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.1] animate-fade-in-up stagger-1">
        Stop wasting money<br/>
        on subscriptions you <span class="gradient-text">forgot about</span>
      </h1>

      <!-- Subtext -->
      <p class="mt-6 text-base sm:text-lg text-slate-400 max-w-xl mx-auto leading-relaxed animate-fade-in-up stagger-2">
        See exactly where your money is going...and what to cancel instantly.
        The average user finds <span class="text-white font-semibold">$43/month</span> in unused services.
      </p>

      <!-- CTA Buttons -->
      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center animate-fade-in-up stagger-3">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="btn-primary px-8 py-3.5 text-white font-bold rounded-xl text-sm shadow-2xl shadow-brand-500/25">
            Go to Dashboard →
          </a>
        <% } else { %>
          <a href="/register" class="btn-primary px-8 py-3.5 text-white font-bold rounded-xl text-sm shadow-2xl shadow-brand-500/25">
            Start Saving Money →
          </a>
          <a href="/login" class="px-8 py-3.5 bg-white/5 text-slate-300 font-semibold rounded-xl border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all text-sm backdrop-blur-sm">
            Sign In
          </a>
        <% } %>
      </div>

      <!-- Mini Dashboard Preview -->
      <div class="mt-16 animate-fade-in-up stagger-4">
        <div class="max-w-2xl mx-auto bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 p-6 shadow-2xl shadow-black/20">
          <!-- Mock stat cards -->
          <div class="grid grid-cols-3 gap-3 mb-5">
            <div class="bg-white/5 rounded-xl p-3.5 border border-white/8 text-left">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 font-medium">Monthly</div>
              <div class="text-2xl font-extrabold text-white">$127</div>
              <div class="text-[10px] text-slate-500 mt-0.5">across 8 services</div>
            </div>
            <div class="bg-white/5 rounded-xl p-3.5 border border-white/8 text-left">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 font-medium">Uses</div>
              <div class="text-2xl font-extrabold text-white">34</div>
              <div class="text-[10px] text-slate-500 mt-0.5">this month</div>
            </div>
            <div class="bg-white/5 rounded-xl p-3.5 border border-emerald-500/20 text-left">
              <div class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 font-medium">Savings</div>
              <div class="text-2xl font-extrabold text-emerald-400">$43</div>
              <div class="text-[10px] text-emerald-600 mt-0.5">found by AI</div>
            </div>
          </div>
          <!-- Mock subscription list -->
          <div class="space-y-2">
            <div class="flex items-center justify-between bg-white/5 rounded-xl px-4 py-2.5 border border-white/5">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full bg-rose-400"></div>
                <span class="text-sm text-slate-300 font-medium">Adobe Creative Cloud</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-slate-500">$54.99</span>
                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-rose-500/15 text-rose-400">Unused</span>
              </div>
            </div>
            <div class="flex items-center justify-between bg-white/5 rounded-xl px-4 py-2.5 border border-white/5">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
                <span class="text-sm text-slate-300 font-medium">Netflix</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-slate-500">$15.49</span>
                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-500/15 text-emerald-400">12 uses</span>
              </div>
            </div>
            <div class="flex items-center justify-between bg-white/5 rounded-xl px-4 py-2.5 border border-white/5">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                <span class="text-sm text-slate-300 font-medium">Spotify</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-slate-500">$10.99</span>
                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-500/15 text-amber-400">3 uses</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── How it Works ───────────────────────────────────────────────────────── -->
<section class="py-20 bg-white relative">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-xs font-bold text-brand-600 uppercase tracking-widest mb-3">How it works</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">Three steps to financial clarity</h2>
      <p class="text-slate-500 text-sm mt-3 max-w-lg mx-auto">No credit card required. Start tracking in under a minute.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="group card-solid p-7 animate-fade-in-up stagger-1 relative">
        <div class="absolute top-6 right-6 text-6xl font-black text-slate-50 select-none pointer-events-none">1</div>
        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white font-bold mb-5 shadow-lg shadow-brand-500/25">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-slate-900 mb-2">Add Subscriptions</h3>
        <p class="text-sm text-slate-500 leading-relaxed">Track Netflix, Spotify, gym, SaaS tools — anything with a recurring cost. Works via web or Telegram.</p>
      </div>
      <div class="group card-solid p-7 animate-fade-in-up stagger-2 relative">
        <div class="absolute top-6 right-6 text-6xl font-black text-slate-50 select-none pointer-events-none">2</div>
        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-white font-bold mb-5 shadow-lg shadow-emerald-500/25">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-slate-900 mb-2">Log Usage</h3>
        <p class="text-sm text-slate-500 leading-relaxed">One tap to record when you actually use a service. Build a real usage history over time.</p>
      </div>
      <div class="group card-solid p-7 animate-fade-in-up stagger-3 relative">
        <div class="absolute top-6 right-6 text-6xl font-black text-slate-50 select-none pointer-events-none">3</div>
        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-violet-500 to-violet-700 flex items-center justify-center text-white font-bold mb-5 shadow-lg shadow-violet-500/25">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-slate-900 mb-2">Get AI Insights</h3>
        <p class="text-sm text-slate-500 leading-relaxed">GPT analyzes your data: cost-per-use, cheaper alternatives, and exactly what to cancel.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── Features ───────────────────────────────────────────────────────────── -->
<section class="py-20 bg-slate-900 relative overflow-hidden">
  <div class="absolute inset-0 hero-grid opacity-40"></div>
  <div class="absolute top-0 right-0 w-80 h-80 bg-brand-500/6 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-violet-500/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-xs font-bold text-brand-400 uppercase tracking-widest mb-3">Capabilities</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">Everything you need to declutter</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <% const feats = [
        { icon:'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', color:'brand', title:'Cost Tracking', body:'Monthly spend breakdown with category charts and yearly totals.' },
        { icon:'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', color:'emerald', title:'Usage Analytics', body:'Track exactly how often you use each service.' },
        { icon:'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', color:'violet', title:'AI Advisor', body:'GPT-4 powered savings suggestions and alternative service finder.' },
        { icon:'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', color:'sky', title:'Telegram Bot', body:'Full control from your chat with daily reminders.' },
      ] %>
      <% feats.forEach(function(f, i) { %>
        <div class="bg-white/5 backdrop-blur-sm p-5 rounded-2xl border border-white/8 hover:border-<%= f.color %>-500/30 transition-all group animate-fade-in-up stagger-<%= i+1 %>">
          <div class="w-10 h-10 rounded-xl bg-<%= f.color %>-500/15 text-<%= f.color %>-400 flex items-center justify-center mb-4 group-hover:bg-<%= f.color %>-500/25 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= f.icon %>" />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-white mb-1.5"><%= f.title %></h3>
          <p class="text-xs text-slate-400 leading-relaxed"><%= f.body %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

