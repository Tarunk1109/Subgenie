      <div class="group card p-8 animate-fade-in-up stagger-3 relative bg-[#fafafa] border border-slate-200 hover:border-slate-300 transition-colors shadow-none hover:shadow-sm rounded-2xl">
        <div class="absolute top-6 right-6 text-5xl font-black text-slate-100 select-none pointer-events-none transition-colors group-hover:text-slate-200">3</div>
        <div class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-[#111111] mb-6 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#111111] mb-2">Get AI Insights</h3>
        <p class="text-sm text-slate-500 leading-relaxed font-medium">GPT analyzes your data: cost-per-use, cheaper alternatives, and exactly what to cancel.</p>
      </div>
    </div>
  </div>
</section>

