<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center relative py-8">
  <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-brand-50/30 to-violet-50/20"></div>
  <div class="absolute top-20 left-1/3 w-64 h-64 bg-violet-200/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 right-1/4 w-48 h-48 bg-brand-200/15 rounded-full blur-3xl"></div>

  <div class="relative w-full max-w-sm mx-auto px-4">
    <div class="text-center mb-6">
      <div class="w-12 h-12 mx-auto rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-lg shadow-brand-500/25 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
      </div>
    </div>

    <div class="bg-white/80 backdrop-blur-xl rounded-2xl border border-white/60 shadow-xl shadow-slate-200/50 p-7">
      <div class="text-center mb-6">
        <h1 class="text-xl font-bold text-slate-900 tracking-tight">Create account</h1>
        <p class="text-slate-500 text-sm mt-1">Start optimizing your subscriptions</p>
      </div>

      <% if (error) { %>
        <div class="mb-5 p-3 bg-rose-50 border border-rose-200/60 text-rose-700 text-xs font-medium rounded-xl"><%= error %></div>
      <% } %>

      <form id="registerForm" action="/register" method="POST" novalidate class="space-y-4">
        <div>
          <label for="name" class="block text-xs font-semibold text-slate-600 mb-1.5">Name</label>
          <input type="text" id="name" name="name"
            class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-50/50 placeholder-slate-400"
            placeholder="Your full name" />
          <p id="errRegName" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <div>
          <label for="email" class="block text-xs font-semibold text-slate-600 mb-1.5">Email</label>
          <input type="email" id="email" name="email"
            class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-50/50 placeholder-slate-400"
            placeholder="you@example.com" />
          <p id="errRegEmail" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <div>
          <label for="password" class="block text-xs font-semibold text-slate-600 mb-1.5">Password</label>
          <input type="password" id="password" name="password"
            class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-50/50 placeholder-slate-400"
            placeholder="At least 6 characters" />
          <p id="errRegPassword" class="text-xs text-rose-600 mt-1 hidden"></p>
          <div id="regStrengthBar" class="hidden mt-2">
            <div class="w-full bg-slate-200 rounded-full h-1.5">
              <div id="regStrengthFill" class="h-1.5 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <p id="regStrengthLabel" class="text-xs mt-1 text-slate-400"></p>
          </div>
        </div>
        <div>
          <label for="confirmPassword" class="block text-xs font-semibold text-slate-600 mb-1.5">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword"
            class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-50/50 placeholder-slate-400"
            placeholder="Repeat your password" />
          <p id="errRegConfirm" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <button type="submit" class="w-full py-2.5 btn-primary text-white text-sm font-semibold rounded-xl">Create Account</button>
      </form>

      <p class="text-center text-xs text-slate-500 mt-6">
        Already have an account?
        <a href="/login" class="text-brand-600 font-semibold hover:text-brand-700 transition">Sign in</a>
      </p>
    </div>
  </div>
</div>

<script>
(function() {
  const pw = document.getElementById('password');
  const bar = document.getElementById('regStrengthBar');
  const fill = document.getElementById('regStrengthFill');
  const label = document.getElementById('regStrengthLabel');
  pw.addEventListener('input', function() {
    const v = pw.value;
    if (!v) { bar.classList.add('hidden'); return; }
    bar.classList.remove('hidden');
    let score = 0;
    if (v.length >= 8) score++;
    if (/[A-Z]/.test(v)) score++;
    if (/[0-9]/.test(v)) score++;
    if (/[^A-Za-z0-9]/.test(v)) score++;
    const levels = [
      { w: '25%', c: 'bg-rose-500', t: 'Weak' },
      { w: '50%', c: 'bg-amber-500', t: 'Fair' },
      { w: '75%', c: 'bg-yellow-500', t: 'Good' },
      { w: '100%', c: 'bg-emerald-500', t: 'Strong' },
    ];
    const l = levels[Math.max(0, score - 1)] || levels[0];
    fill.style.width = l.w;
    fill.className = 'h-1.5 rounded-full transition-all duration-300 ' + l.c;
    label.textContent = l.t;
  });
  document.getElementById('registerForm').addEventListener('submit', function(e) {
    let ok = true;
    ['errRegName','errRegEmail','errRegPassword','errRegConfirm'].forEach(id => { document.getElementById(id).classList.add('hidden'); });
    const name = document.getElementById('name').value.trim();
    const email = document.getElementById('email').value.trim();
    const pass = document.getElementById('password').value;
    const confirm = document.getElementById('confirmPassword').value;
    if (!name) { show('errRegName', 'Name is required'); ok = false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { show('errRegEmail', 'Enter a valid email'); ok = false; }
    if (pass.length < 6) { show('errRegPassword', 'Password must be at least 6 characters'); ok = false; }
    if (pass !== confirm) { show('errRegConfirm', 'Passwords do not match'); ok = false; }
    if (!ok) e.preventDefault();
  });
  function show(id, msg) { const el = document.getElementById(id); el.textContent = msg; el.classList.remove('hidden'); }
})();
</script>
