<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center relative py-8">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-brand-50/40 to-violet-50/30"></div>
  <div class="absolute top-20 right-1/3 w-72 h-72 bg-brand-200/20 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-20 left-1/4 w-56 h-56 bg-violet-200/15 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative w-full max-w-sm mx-auto px-4">
    <!-- Logo mark -->
    <div class="text-center mb-7 animate-fade-in-up">
      <a href="/" class="inline-flex flex-col items-center gap-3">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-xl shadow-brand-500/30">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <span class="text-xl font-extrabold text-slate-900 tracking-tight">SubGenie</span>
      </a>
    </div>

    <!-- Card -->
    <div class="bg-white/85 backdrop-blur-xl rounded-2xl border border-white/70 shadow-2xl shadow-slate-200/50 p-8 animate-fade-in-up stagger-1">
      <div class="text-center mb-7">
        <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Welcome back</h1>
        <p class="text-slate-500 text-sm mt-1.5">Sign in to continue to SubGenie</p>
      </div>

      <% if (error) { %>
        <div class="mb-5 flex items-center gap-2.5 p-3.5 bg-rose-50 border border-rose-200 text-rose-700 text-xs font-medium rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.072 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
          <%= error %>
        </div>
      <% } %>

      <form id="loginForm" action="/login" method="POST" novalidate class="space-y-4">
        <div>
          <label for="email" class="form-label">Email</label>
          <input type="email" id="email" name="email"
            class="form-input" placeholder="you@example.com" autocomplete="email" />
          <p id="errLoginEmail" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <div>
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="password"
            class="form-input" placeholder="Enter your password" autocomplete="current-password" />
          <p id="errLoginPassword" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <button type="submit" class="w-full py-3 btn-primary text-white text-sm font-bold rounded-xl mt-2">
          Sign In →
        </button>
      </form>

      <p class="text-center text-xs text-slate-500 mt-6">
        Don't have an account?
        <a href="/register" class="text-brand-600 font-bold hover:text-brand-700 transition">Create one free</a>
      </p>
    </div>
  </div>
</div>

<script>
(function() {
  document.getElementById('loginForm').addEventListener('submit', function(e) {
    let ok = true;
    document.getElementById('errLoginEmail').classList.add('hidden');
    document.getElementById('errLoginPassword').classList.add('hidden');
    const email = document.getElementById('email').value.trim();
    const pass  = document.getElementById('password').value;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      const el = document.getElementById('errLoginEmail');
      el.textContent = 'Enter a valid email address';
      el.classList.remove('hidden');
      ok = false;
    }
    if (!pass) {
      const el = document.getElementById('errLoginPassword');
      el.textContent = 'Password is required';
      el.classList.remove('hidden');
      ok = false;
    }
    if (!ok) e.preventDefault();
  });
})();
</script>
