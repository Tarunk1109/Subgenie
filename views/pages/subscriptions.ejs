<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-slate-900 tracking-tight">Subscriptions</h1>
      <p class="text-slate-500 text-sm">Manage recurring expenses</p>
    </div>
    <button onclick="openAddModal()"
      class="mt-3 sm:mt-0 px-4 py-2 bg-brand-600 text-white text-sm font-semibold rounded-md hover:bg-brand-500 transition flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
      Add
    </button>
  </div>

  <!-- Search / Filter Bar -->
  <form method="GET" action="/subscriptions" class="bg-white rounded-lg border border-slate-200 p-4 mb-4">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      <div class="col-span-2 sm:col-span-1">
        <input type="text" name="q" value="<%= q %>" placeholder="Search by name..."
          class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm" />
      </div>
      <div>
        <select name="category" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm bg-white">
          <option value="">All Categories</option>
          <% allCategories.forEach(function(cat) { %>
            <option value="<%= cat %>" <%= categoryFilter === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <select name="billingCycle" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm bg-white">
          <option value="">All Cycles</option>
          <option value="monthly" <%= billingCycleFilter === 'monthly' ? 'selected' : '' %>>Monthly</option>
          <option value="yearly" <%= billingCycleFilter === 'yearly' ? 'selected' : '' %>>Yearly</option>
        </select>
      </div>
      <div>
        <select name="sort" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm bg-white">
          <option value="newest" <%= sortParam === 'newest' ? 'selected' : '' %>>Newest</option>
          <option value="oldest" <%= sortParam === 'oldest' ? 'selected' : '' %>>Oldest</option>
          <option value="name-asc" <%= sortParam === 'name-asc' ? 'selected' : '' %>>Name A-Z</option>
          <option value="name-desc" <%= sortParam === 'name-desc' ? 'selected' : '' %>>Name Z-A</option>
          <option value="cost-asc" <%= sortParam === 'cost-asc' ? 'selected' : '' %>>Cheapest</option>
          <option value="cost-desc" <%= sortParam === 'cost-desc' ? 'selected' : '' %>>Most Expensive</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="flex-1 px-3 py-2 bg-brand-600 text-white text-sm font-medium rounded-md hover:bg-brand-500 transition">Apply</button>
        <a href="/subscriptions" class="px-3 py-2 text-sm text-slate-500 hover:text-slate-700 border border-slate-300 rounded-md transition text-center">Clear</a>
      </div>
    </div>
    <div class="mt-2 text-xs text-slate-400"><%= totalCount %> result<%= totalCount !== 1 ? 's' : '' %></div>
  </form>

  <% if (subscriptions.length > 0) { %>
    <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs text-slate-500 uppercase tracking-wide bg-slate-50 border-b border-slate-200">
              <th class="px-5 py-3 font-medium">Name</th>
              <th class="px-5 py-3 font-medium">Category</th>
              <th class="px-5 py-3 font-medium">Cost</th>
              <th class="px-5 py-3 font-medium">Cycle</th>
              <th class="px-5 py-3 font-medium text-center">Uses</th>
              <th class="px-5 py-3 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% subscriptions.forEach(function(sub) { %>
              <tr class="border-b border-slate-50 table-row-alt hover:bg-slate-50 transition">
                <td class="px-5 py-3 font-medium text-slate-800"><%= sub.name %></td>
                <td class="px-5 py-3 text-slate-500"><%= sub.category %></td>
                <td class="px-5 py-3 text-slate-800 font-medium">$<%= sub.cost.toFixed(2) %></td>
                <td class="px-5 py-3"><span class="px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600"><%= sub.billingCycle %></span></td>
                <td class="px-5 py-3 text-center">
                  <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold
                    <%= sub.useCount > 3 ? 'bg-emerald-50 text-emerald-700' : sub.useCount > 0 ? 'bg-amber-50 text-amber-700' : 'bg-rose-50 text-rose-600' %>">
                    <%= sub.useCount %>
                  </span>
                </td>
                <td class="px-5 py-3 text-right">
                  <div class="flex items-center justify-end gap-1">
                    <button onclick="logUsage('<%= sub._id %>')" title="Log use" class="p-1.5 text-emerald-600 hover:bg-emerald-50 rounded transition">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    </button>
                    <a href="/usage/<%= sub._id %>" title="History" class="p-1.5 text-slate-400 hover:bg-slate-100 hover:text-slate-600 rounded transition">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </a>
                    <button onclick="findAlternatives('<%= sub._id %>', '<%= sub.name %>')" title="Find Alternatives" class="p-1.5 text-violet-400 hover:bg-violet-50 hover:text-violet-600 rounded transition">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
                    </button>
                    <% if (user.role === 'admin') { %>
                      <button onclick="openEditModal('<%= sub._id %>', '<%= sub.name %>', <%= sub.cost %>, '<%= sub.category %>', '<%= sub.billingCycle %>')" title="Edit" class="p-1.5 text-slate-400 hover:bg-slate-100 hover:text-slate-600 rounded transition">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                      </button>
                      <button onclick="deleteSubscription('<%= sub._id %>')" title="Delete" class="p-1.5 text-slate-400 hover:bg-rose-50 hover:text-rose-600 rounded transition">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                      </button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (totalPages > 1) { %>
      <div class="flex items-center justify-center gap-1 mt-4">
        <% if (currentPage > 1) { %>
          <a href="/subscriptions?q=<%= q %>&category=<%= categoryFilter %>&billingCycle=<%= billingCycleFilter %>&sort=<%= sortParam %>&page=<%= currentPage - 1 %>" class="px-3 py-1.5 text-sm text-slate-600 border border-slate-300 rounded-md hover:bg-slate-50 transition">Prev</a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="/subscriptions?q=<%= q %>&category=<%= categoryFilter %>&billingCycle=<%= billingCycleFilter %>&sort=<%= sortParam %>&page=<%= i %>"
            class="px-3 py-1.5 text-sm rounded-md border transition <%= i === currentPage ? 'bg-brand-600 text-white border-brand-600' : 'text-slate-600 border-slate-300 hover:bg-slate-50' %>"><%= i %></a>
        <% } %>
        <% if (currentPage < totalPages) { %>
          <a href="/subscriptions?q=<%= q %>&category=<%= categoryFilter %>&billingCycle=<%= billingCycleFilter %>&sort=<%= sortParam %>&page=<%= currentPage + 1 %>" class="px-3 py-1.5 text-sm text-slate-600 border border-slate-300 rounded-md hover:bg-slate-50 transition">Next</a>
        <% } %>
      </div>
    <% } %>
  <% } else { %>
    <div class="bg-white rounded-lg border border-slate-200 p-12 text-center">
      <% if (q || categoryFilter || billingCycleFilter) { %>
        <p class="text-slate-500 text-sm mb-3">No subscriptions match your filters</p>
        <a href="/subscriptions" class="text-brand-600 text-sm font-medium hover:underline">Clear filters</a>
      <% } else { %>
        <p class="text-slate-500 text-sm mb-3">No subscriptions yet</p>
        <button onclick="openAddModal()" class="px-4 py-2 bg-brand-600 text-white text-sm font-semibold rounded-md hover:bg-brand-500 transition">Add Your First Subscription</button>
      <% } %>
    </div>
  <% } %>
</div>

<!-- Add/Edit Modal -->
<div id="subModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
  <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4 p-5 animate-fade-in-up">
    <div class="flex items-center justify-between mb-5">
      <h2 id="modalTitle" class="text-lg font-bold text-slate-900">Add Subscription</h2>
      <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
    <form id="subscriptionForm" class="space-y-3">
      <input type="hidden" id="editSubId" value="" />
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Name</label>
        <input type="text" id="subName" name="name" placeholder="e.g. Netflix, Spotify" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm" />
        <p id="errName" class="text-xs text-rose-600 mt-1 hidden"></p>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Cost ($)</label>
          <input type="number" id="subCost" name="cost" min="0" step="0.01" placeholder="15.99" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm" />
          <p id="errCost" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Billing Cycle</label>
          <select id="subCycle" name="billingCycle" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm bg-white">
            <option value="monthly">Monthly</option>
            <option value="yearly">Yearly</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Category</label>
        <input type="text" id="subCategory" name="category" placeholder="e.g. Entertainment, Fitness" class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm" />
        <p id="errCategory" class="text-xs text-rose-600 mt-1 hidden"></p>
      </div>
      <button type="submit" id="modalSubmitBtn" class="w-full py-2 bg-brand-600 text-white text-sm font-semibold rounded-md hover:bg-brand-500 transition">Add Subscription</button>
    </form>
  </div>
</div>

<!-- Alternatives Modal -->
<div id="altModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
  <div class="bg-white rounded-lg shadow-xl max-w-lg w-full mx-4 max-h-[80vh] overflow-y-auto animate-fade-in-up">
    <div class="sticky top-0 bg-white border-b border-slate-100 px-5 py-4 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-bold text-slate-900">Alternatives</h2>
        <p id="altSubName" class="text-xs text-slate-500"></p>
      </div>
      <button onclick="document.getElementById('altModal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
    <div id="altContent" class="p-5">
      <div class="flex items-center justify-center py-8">
        <svg class="h-5 w-5 animate-spin text-brand-600" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4" stroke-linecap="round"/></svg>
        <span class="ml-2 text-sm text-slate-500">Finding alternatives...</span>
      </div>
    </div>
  </div>
</div>
