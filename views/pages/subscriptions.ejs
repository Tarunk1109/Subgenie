<!-- ─── Header ────────────────────────────────────────────────────────────── -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-5 animate-fade-in-up">
  <div>
    <p class="section-kicker">Catalog</p>
    <p class="text-slate-500 text-sm"><%= totalCount %> subscription<%= totalCount !== 1 ? 's' : '' %> in your workspace</p>
  </div>
  <button onclick="openAddModal()"
    class="btn-primary px-4 py-2 text-white text-sm font-semibold rounded-xl flex items-center gap-2 self-start sm:self-auto">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
    </svg>
    Add Subscription
  </button>
</div>

<!-- ─── Filters ───────────────────────────────────────────────────────────── -->
<div class="card-solid p-4 mb-4 animate-fade-in-up stagger-1">
  <form method="GET" action="/subscriptions">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      <!-- Search -->
      <div class="col-span-2 sm:col-span-1 lg:col-span-2">
        <div class="search-bar">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input type="text" name="q" value="<%= q %>" placeholder="Search subscriptions…" />
        </div>
      </div>
      <!-- Category -->
      <div>
        <select name="category" class="form-input">
          <option value="">All Categories</option>
          <% allCategories.forEach(function(cat) { %>
            <option value="<%= cat %>" <%= categoryFilter === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <!-- Cycle -->
      <div>
        <select name="billingCycle" class="form-input">
          <option value="">All Cycles</option>
          <option value="monthly" <%= billingCycleFilter === 'monthly' ? 'selected' : '' %>>Monthly</option>
          <option value="yearly"  <%= billingCycleFilter === 'yearly'  ? 'selected' : '' %>>Yearly</option>
        </select>
      </div>
      <!-- Sort -->
      <div>
        <select name="sort" class="form-input">
          <option value="newest"    <%= sortParam === 'newest'    ? 'selected' : '' %>>Newest first</option>
          <option value="oldest"    <%= sortParam === 'oldest'    ? 'selected' : '' %>>Oldest first</option>
          <option value="name-asc"  <%= sortParam === 'name-asc'  ? 'selected' : '' %>>Name A–Z</option>
          <option value="name-desc" <%= sortParam === 'name-desc' ? 'selected' : '' %>>Name Z–A</option>
          <option value="cost-asc"  <%= sortParam === 'cost-asc'  ? 'selected' : '' %>>Cheapest</option>
          <option value="cost-desc" <%= sortParam === 'cost-desc' ? 'selected' : '' %>>Most expensive</option>
        </select>
      </div>
      <!-- Actions -->
      <div class="flex gap-2">
        <button type="submit" class="flex-1 btn-primary py-2 text-white text-sm font-semibold rounded-xl">Filter</button>
        <a href="/subscriptions" title="Clear filters"
           class="flex items-center justify-center px-3 py-2 border border-slate-200 rounded-xl text-slate-500 hover:text-slate-700 hover:bg-slate-50 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Active filter chips -->
    <% if (q || categoryFilter || billingCycleFilter) { %>
    <div class="flex flex-wrap gap-2 mt-3">
      <% if (q) { %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-brand-50 text-brand-700 text-xs font-semibold rounded-full border border-brand-200">
          Search: "<%= q %>"
        </span>
      <% } %>
      <% if (categoryFilter) { %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-violet-50 text-violet-700 text-xs font-semibold rounded-full border border-violet-200">
          Category: <%= categoryFilter %>
        </span>
      <% } %>
      <% if (billingCycleFilter) { %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full border border-blue-200">
          Cycle: <%= billingCycleFilter %>
        </span>
      <% } %>
    </div>
    <% } %>
  </form>
</div>

<!-- ─── Subscriptions Table ───────────────────────────────────────────────── -->
<% if (subscriptions.length > 0) { %>
  <div class="card-solid overflow-hidden animate-fade-in-up stagger-2">
    <div class="overflow-x-auto">
      <table class="w-full table-modern">
        <thead>
          <tr>
            <th class="text-left">Name</th>
            <th class="text-left hidden sm:table-cell">Category</th>
            <th class="text-left">Cost</th>
            <th class="text-left hidden md:table-cell">Cycle</th>
            <th class="text-center">Uses</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% subscriptions.forEach(function(sub, i) { %>
            <tr class="animate-fade-in-up" style="animation-delay: <%= i * 0.04 %>s">
              <td>
                <div class="flex items-center gap-3">
                  <div class="service-avatar" data-service="<%= sub.name %>">
                    <%= sub.name.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <div class="font-semibold text-slate-800 text-sm leading-tight"><%= sub.name %></div>
                    <div class="text-xs text-slate-400 sm:hidden"><%= sub.category %></div>
                  </div>
                </div>
              </td>
              <td class="hidden sm:table-cell">
                <span class="cat-pill"><%= sub.category %></span>
              </td>
              <td>
                <div>
                  <span class="font-bold text-slate-800 text-sm">$<%= sub.cost.toFixed(2) %></span>
                  <% if (sub.billingCycle === 'yearly') { %>
                    <div class="text-xs text-slate-400">$<%= (sub.cost/12).toFixed(2) %>/mo</div>
                  <% } %>
                </div>
              </td>
              <td class="hidden md:table-cell">
                <span class="text-xs px-2.5 py-1 rounded-lg font-semibold cycle-<%= sub.billingCycle %>">
                  <%= sub.billingCycle.charAt(0).toUpperCase() + sub.billingCycle.slice(1) %>
                </span>
              </td>
              <td>
                <div class="flex justify-center">
                  <span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold
                    <%= sub.useCount > 3 ? 'bg-emerald-50 text-emerald-700' :
                       sub.useCount > 0 ? 'bg-amber-50 text-amber-700' :
                                          'bg-rose-50 text-rose-600' %>">
                    <%= sub.useCount %>
                  </span>
                </div>
              </td>
              <td>
                <div class="flex items-center justify-end gap-1">
                  <button onclick="logUsage('<%= sub._id %>')" title="Log use"
                    class="p-1.5 text-emerald-600 hover:bg-emerald-50 rounded-lg transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </button>
                  <a href="/usage/<%= sub._id %>" title="Usage history"
                    class="p-1.5 text-slate-400 hover:bg-slate-100 hover:text-slate-600 rounded-lg transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </a>
                  <button onclick="findAlternatives('<%= sub._id %>','<%= sub.name.replace(/'/g, "\\'") %>')" title="AI alternatives"
                    class="p-1.5 text-violet-500 hover:bg-violet-50 hover:text-violet-700 rounded-lg transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                    </svg>
                  </button>
                  <button onclick="openEditModal('<%= sub._id %>','<%= sub.name.replace(/'/g, "\\'") %>',<%= sub.cost %>,'<%= sub.category.replace(/'/g, "\\'") %>','<%= sub.billingCycle %>')" title="Edit"
                    class="p-1.5 text-slate-400 hover:bg-slate-100 hover:text-slate-700 rounded-lg transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </button>
                  <button onclick="deleteSubscription('<%= sub._id %>')" title="Delete"
                    class="p-1.5 text-slate-400 hover:bg-rose-50 hover:text-rose-600 rounded-lg transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="flex items-center justify-center gap-1.5 mt-4">
    <% if (currentPage > 1) { %>
      <a href="/subscriptions?q=<%= q %>&category=<%= categoryFilter %>&billingCycle=<%= billingCycleFilter %>&sort=<%= sortParam %>&page=<%= currentPage - 1 %>"
         class="page-btn">‹</a>
    <% } %>
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="/subscriptions?q=<%= q %>&category=<%= categoryFilter %>&billingCycle=<%= billingCycleFilter %>&sort=<%= sortParam %>&page=<%= i %>"
         class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
    <% } %>
    <% if (currentPage < totalPages) { %>
      <a href="/subscriptions?q=<%= q %>&category=<%= categoryFilter %>&billingCycle=<%= billingCycleFilter %>&sort=<%= sortParam %>&page=<%= currentPage + 1 %>"
         class="page-btn">›</a>
    <% } %>
  </div>
  <% } %>

<% } else { %>
  <div class="card-solid animate-fade-in-up stagger-2">
    <div class="empty-state py-16">
      <% if (q || categoryFilter || billingCycleFilter) { %>
        <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <p class="text-sm font-semibold text-slate-600 mb-1">No results found</p>
        <p class="text-xs text-slate-400 mb-4">Try adjusting your filters</p>
        <a href="/subscriptions" class="text-brand-600 text-sm font-semibold hover:underline">Clear all filters</a>
      <% } else { %>
        <div class="w-16 h-16 rounded-2xl bg-brand-50 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </div>
        <p class="text-sm font-semibold text-slate-600 mb-1">No subscriptions yet</p>
        <p class="text-xs text-slate-400 mb-4">Start tracking your recurring expenses</p>
        <button onclick="openAddModal()" class="btn-primary px-5 py-2 text-white text-sm font-bold rounded-xl">
          Add Your First Subscription
        </button>
      <% } %>
    </div>
  </div>
<% } %>

<!-- ─── Add/Edit Modal ────────────────────────────────────────────────────── -->
<div id="subModal" class="hidden modal-backdrop">
  <div class="modal-box modal-box-premium">
    <div class="modal-header">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-100 to-violet-100 border border-brand-200/50 flex items-center justify-center shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </div>
        <h2 id="modalTitle" class="text-base font-bold text-slate-900">Add Subscription</h2>
      </div>
      <button onclick="closeModal()" class="p-1.5 rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="subscriptionForm" class="space-y-4">
        <input type="hidden" id="editSubId" value="" />
        <div>
          <label class="form-label">Subscription Name</label>
          <input type="text" id="subName" name="name" class="form-input" placeholder="e.g. Netflix, Spotify…" autocomplete="off" />
          <p id="errName" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label">Cost ($)</label>
            <input type="number" id="subCost" name="cost" min="0" step="0.01" class="form-input" placeholder="15.99" />
            <p id="errCost" class="text-xs text-rose-600 mt-1 hidden"></p>
          </div>
          <div>
            <label class="form-label">Billing Cycle</label>
            <select id="subCycle" name="billingCycle" class="form-input">
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
        </div>
        <div>
          <label class="form-label">Category</label>
          <input type="text" id="subCategory" name="category" class="form-input" placeholder="e.g. Entertainment, Fitness…" autocomplete="off" />
          <p id="errCategory" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <button type="submit" id="modalSubmitBtn" class="w-full py-2.5 btn-primary text-white text-sm font-bold rounded-xl">
          Add Subscription
        </button>
      </form>
    </div>
  </div>
</div>

<!-- ─── Alternatives Modal ────────────────────────────────────────────────── -->
<div id="altModal" class="hidden modal-backdrop">
  <div class="modal-box modal-box-premium max-w-lg" style="max-height: 80vh; overflow-y: auto;">
    <div class="modal-header sticky top-0 bg-white/95 backdrop-blur-md z-10 border-b border-slate-100">
      <div>
        <h2 class="text-base font-bold text-slate-900">AI Alternatives</h2>
        <p id="altSubName" class="text-xs text-slate-500 mt-0.5"></p>
      </div>
      <button onclick="document.getElementById('altModal').classList.add('hidden')"
        class="p-1.5 rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="altContent" class="modal-body"></div>
  </div>
</div>
