<!-- ─── Greeting ──────────────────────────────────────────────────────────── -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h2 class="text-2xl font-bold text-slate-900 tracking-tight">
      Good <%= new Date().getHours() < 12 ? 'morning' : new Date().getHours() < 17 ? 'afternoon' : 'evening' %>,
      <%= user.name.split(' ')[0] %> 👋
    </h2>
    <p class="text-slate-500 text-sm mt-0.5">Here's your subscription overview for <%= new Date().toLocaleString('en-US', { month: 'long', year: 'numeric' }) %></p>
  </div>
  <a href="/subscriptions" class="btn-primary px-4 py-2 text-white text-sm font-semibold rounded-xl flex items-center gap-2 self-start sm:self-auto">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
    Add Subscription
  </a>
</div>

<!-- ─── Stat Cards ────────────────────────────────────────────────────────── -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

  <!-- Active Subscriptions -->
  <div class="stat-card stat-card-indigo animate-fade-in-up stagger-1">
    <div class="stat-card-accent"></div>
    <div class="stat-card-icon bg-brand-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
    </div>
    <div class="text-3xl font-extrabold text-slate-900 tracking-tight leading-none"><%= totalSubs %></div>
    <div class="text-xs font-medium text-slate-500 mt-1.5">Active Subscriptions</div>
  </div>

  <!-- Monthly Spend -->
  <div class="stat-card stat-card-emerald animate-fade-in-up stagger-2">
    <div class="stat-card-accent"></div>
    <div class="stat-card-icon bg-emerald-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <div class="text-3xl font-extrabold text-slate-900 tracking-tight leading-none">$<%= totalMonthlySpend %></div>
    <div class="text-xs font-medium text-slate-500 mt-1.5">Monthly Spend</div>
  </div>

  <!-- Uses This Month -->
  <div class="stat-card stat-card-amber animate-fade-in-up stagger-3">
    <div class="stat-card-accent"></div>
    <div class="stat-card-icon bg-amber-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
      </svg>
    </div>
    <div class="text-3xl font-extrabold text-slate-900 tracking-tight leading-none"><%= usesThisMonth %></div>
    <div class="text-xs font-medium text-slate-500 mt-1.5">Uses This Month</div>
  </div>

  <!-- Avg Cost/Use -->
  <div class="stat-card stat-card-rose animate-fade-in-up stagger-4">
    <div class="stat-card-accent"></div>
    <div class="stat-card-icon bg-rose-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
      </svg>
    </div>
    <div class="text-3xl font-extrabold text-slate-900 tracking-tight leading-none">
      <%= avgCostPerUse === 'N/A' ? '—' : '$' + avgCostPerUse %>
    </div>
    <div class="text-xs font-medium text-slate-500 mt-1.5">Avg Cost / Use</div>
  </div>
</div>

<!-- ─── Charts + Activity ─────────────────────────────────────────────────── -->
<div class="grid lg:grid-cols-5 gap-5 mb-5">

  <!-- Spending by Category -->
  <div class="lg:col-span-2 card p-5 animate-fade-in-up stagger-2">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-slate-900">Spending by Category</h3>
      <span class="text-xs text-slate-400">Monthly</span>
    </div>
    <% if (Object.keys(categorySpend).length > 0) { %>
      <div class="relative h-56">
        <canvas id="categoryChart"></canvas>
      </div>
    <% } else { %>
      <div class="empty-state h-56 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-3 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" />
        </svg>
        <p class="text-sm font-medium">No data yet</p>
        <p class="text-xs text-slate-400 mt-1">Add subscriptions to see chart</p>
      </div>
    <% } %>
  </div>

  <!-- Recent Activity -->
  <div class="lg:col-span-3 card p-5 animate-fade-in-up stagger-3">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-slate-900">Recent Activity</h3>
      <a href="/subscriptions" class="text-xs text-brand-600 hover:text-brand-700 font-semibold transition">View all →</a>
    </div>
    <% if (recentLogs.length > 0) { %>
      <div>
        <% recentLogs.forEach(function(log, i) { %>
          <div class="activity-item animate-fade-in-up stagger-<%= Math.min(i+1,4) %>">
            <div class="relative">
              <div class="activity-dot <%= log.action === 'used' ? 'bg-emerald-500' : 'bg-slate-300' %>"></div>
              <% if (i < recentLogs.length - 1) { %>
                <div class="absolute top-3 left-[3.5px] w-px h-6 bg-slate-100"></div>
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-slate-700 truncate">
                  <%= log.subscription ? log.subscription.name : 'Unknown' %>
                </span>
                <span class="text-[11px] px-2 py-0.5 rounded-full font-semibold flex-shrink-0
                  <%= log.action === 'used' ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
                  <%= log.action === 'used' ? 'Used' : 'Not used' %>
                </span>
              </div>
            </div>
            <span class="text-xs text-slate-400 flex-shrink-0">
              <%= new Date(log.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
            </span>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state py-8 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-2 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm">No usage logged yet</p>
        <p class="text-xs mt-1 text-slate-400">Log usage from the Subscriptions page</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ─── Subscription List ─────────────────────────────────────────────────── -->
<div class="card animate-fade-in-up stagger-4">
  <div class="flex items-center justify-between px-5 pt-5 pb-3">
    <div>
      <h3 class="text-sm font-bold text-slate-900">Subscriptions</h3>
      <p class="text-xs text-slate-400 mt-0.5"><%= subscriptions.length %> active</p>
    </div>
    <a href="/subscriptions" class="text-xs text-brand-600 hover:text-brand-700 font-semibold transition">Manage all →</a>
  </div>

  <% if (subscriptions.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full table-modern">
        <thead>
          <tr>
            <th class="text-left">Name</th>
            <th class="text-left hidden sm:table-cell">Category</th>
            <th class="text-left">Cost</th>
            <th class="text-left hidden md:table-cell">Cycle</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% subscriptions.forEach(function(sub) { %>
            <tr>
              <td>
                <div class="flex items-center gap-2.5">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-100 to-brand-200 flex items-center justify-center text-brand-700 text-xs font-bold flex-shrink-0">
                    <%= sub.name.charAt(0).toUpperCase() %>
                  </div>
                  <span class="font-semibold text-slate-800 text-sm"><%= sub.name %></span>
                </div>
              </td>
              <td class="hidden sm:table-cell">
                <span class="cat-pill"><%= sub.category %></span>
              </td>
              <td>
                <span class="font-bold text-slate-800 text-sm">$<%= sub.cost.toFixed(2) %></span>
              </td>
              <td class="hidden md:table-cell">
                <span class="text-xs px-2 py-1 rounded-lg font-semibold cycle-<%= sub.billingCycle %>"><%= sub.billingCycle %></span>
              </td>
              <td>
                <div class="flex items-center justify-end gap-1">
                  <button onclick="logUsage('<%= sub._id %>')"
                    class="px-2.5 py-1.5 text-xs font-semibold bg-emerald-50 text-emerald-700 rounded-lg hover:bg-emerald-100 transition">
                    Log Use
                  </button>
                  <button onclick="openEditModal('<%= sub._id %>','<%= sub.name.replace(/'/g, "\\'") %>',<%= sub.cost %>,'<%= sub.category.replace(/'/g, "\\'") %>','<%= sub.billingCycle %>')"
                    class="px-2.5 py-1.5 text-xs font-semibold bg-slate-50 text-slate-600 rounded-lg hover:bg-slate-100 transition">
                    Edit
                  </button>
                  <button onclick="deleteSubscription('<%= sub._id %>')"
                    class="px-2.5 py-1.5 text-xs font-semibold bg-rose-50 text-rose-600 rounded-lg hover:bg-rose-100 transition">
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <div class="w-16 h-16 rounded-2xl bg-brand-50 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
      </div>
      <p class="text-sm font-semibold text-slate-600 mb-1">No subscriptions yet</p>
      <p class="text-xs text-slate-400 mb-4">Add your first subscription to start tracking</p>
      <button onclick="openAddModal()" class="btn-primary px-5 py-2 text-white text-sm font-semibold rounded-xl">
        Add First Subscription
      </button>
    </div>
  <% } %>
</div>

<!-- ─── Add/Edit Modal ────────────────────────────────────────────────────── -->
<div id="subModal" class="hidden modal-backdrop">
  <div class="modal-box">
    <div class="modal-header">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-brand-50 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </div>
        <h2 id="modalTitle" class="text-base font-bold text-slate-900">Add Subscription</h2>
      </div>
      <button onclick="closeModal()" class="p-1.5 rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="subscriptionForm" class="space-y-4">
        <input type="hidden" id="editSubId" value="" />
        <div>
          <label class="form-label">Subscription Name</label>
          <input type="text" id="subName" name="name" class="form-input" placeholder="e.g. Netflix, Spotify…" />
          <p id="errName" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label">Cost ($)</label>
            <input type="number" id="subCost" name="cost" min="0" step="0.01" class="form-input" placeholder="15.99" />
            <p id="errCost" class="text-xs text-rose-600 mt-1 hidden"></p>
          </div>
          <div>
            <label class="form-label">Billing Cycle</label>
            <select id="subCycle" name="billingCycle" class="form-input">
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
        </div>
        <div>
          <label class="form-label">Category</label>
          <input type="text" id="subCategory" name="category" class="form-input" placeholder="e.g. Entertainment, Fitness…" />
          <p id="errCategory" class="text-xs text-rose-600 mt-1 hidden"></p>
        </div>
        <button type="submit" id="modalSubmitBtn" class="w-full py-2.5 btn-primary text-white text-sm font-bold rounded-xl">
          Add Subscription
        </button>
      </form>
    </div>
  </div>
</div>

<!-- ─── Chart init ────────────────────────────────────────────────────────── -->
<% if (Object.keys(categorySpend).length > 0) { %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    initCategoryChart(<%- JSON.stringify(categorySpend) %>);
  });
</script>
<% } %>
