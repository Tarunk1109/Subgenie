<%- include('partials/header', { pageTitle: 'Login', user: null }) %>

<div class="flex items-center justify-center min-h-[calc(100vh-8rem)]">
  <div class="w-full max-w-sm mx-auto px-4">
    <div class="bg-white rounded-lg border border-slate-200 shadow-sm p-6">
      <div class="text-center mb-6">
        <h1 class="text-xl font-bold text-slate-900 tracking-tight">Sign in</h1>
        <p class="text-slate-500 text-sm mt-1">Access your SubGenie dashboard</p>
      </div>

      <% if (error) { %>
        <div class="mb-4 p-2.5 bg-rose-50 border border-rose-200 text-rose-700 text-xs font-medium rounded-md">
          <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST" class="space-y-4">
        <div>
          <label for="email" class="block text-xs font-medium text-slate-600 mb-1">Email</label>
          <input type="email" id="email" name="email" required
            class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm bg-white"
            placeholder="you@example.com" />
        </div>
        <div>
          <label for="password" class="block text-xs font-medium text-slate-600 mb-1">Password</label>
          <input type="password" id="password" name="password" required
            class="w-full px-3 py-2 border border-slate-300 rounded-md text-sm bg-white"
            placeholder="Enter your password" />
        </div>
        <button type="submit"
          class="w-full py-2 bg-brand-600 text-white text-sm font-semibold rounded-md hover:bg-brand-500 transition">
          Sign In
        </button>
      </form>

      <p class="text-center text-xs text-slate-500 mt-5">
        Don't have an account?
        <a href="/register" class="text-brand-600 font-medium hover:underline">Sign up</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
