# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string — replace <username>, <password>, <cluster>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=subgenie

# ─── Authentication ───────────────────────────────────────────────────────────
# Use a strong, random 64-char secret in production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_chars

# ─── Telegram Bot (optional) ─────────────────────────────────────────────────
# Obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── OpenAI (optional — enables AI features) ─────────────────────────────────
OPENAI_API_KEY=

# ─── CORS (optional — set to your frontend domain in production) ─────────────
# CLIENT_ORIGIN=https://yourapp.onrender.com
